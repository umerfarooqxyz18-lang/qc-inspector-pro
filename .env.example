# ════════════════════════════════════════════════════════════
#  AI QC Inspector Pro — Backend Environment Variables
#  HOW TO USE:
#    1. Copy this file:  cp .env.example .env
#    2. Fill in every value below
#    3. Never commit .env to Git
# ════════════════════════════════════════════════════════════

# ── SUPABASE ─────────────────────────────────────────────────
#  Where to find: supabase.com → your project → Settings → API
#
#  Project URL (looks like: https://abcxyz.supabase.co)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

#  Anon / public key  (safe to use in backend for auth verification)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY

#  Service role key   (KEEP SECRET — gives full DB access, backend only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_KEY

# ── ANTHROPIC (Claude AI) ────────────────────────────────────
#  Where to find: console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ── SERVER ───────────────────────────────────────────────────
#  Port the backend listens on (Railway sets this automatically)
PORT=3001

#  Set to "production" when deployed
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────
#  Comma-separated list of frontend origins allowed to call this API
#  Example prod value: https://myapp.vercel.app
#  Example local dev:  http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://YOUR_FRONTEND.vercel.app
